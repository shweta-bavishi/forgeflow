   *
   * @param filters - Optional filter criteria
   * @returns Array of matching entities
   */
  async findActive(filters?: Partial<{{pascalCase name}}>): Promise<{{pascalCase name}}[]> {
    const qb = this.createQueryBuilder('{{camelCase name}}')
      .where('{{camelCase name}}.isActive = :isActive', { isActive: true });

    if (filters) {
      Object.entries(filters).forEach(([key, value]) => {
        if (value !== undefined) {
          qb.andWhere(`{{camelCase name}}.${key} = :${key}`, { [key]: value });
        }
      });
    }

    return await qb.orderBy('{{camelCase name}}.createdAt', 'DESC').getMany();
  }

  /**
   * Check if a {{camelCase name}} exists by ID.
   *
