import { Injectable } from '@nestjs/common';
import { DataSource, Repository } from 'typeorm';
import { {{pascalCase name}} } from '../entities/{{kebabCase name}}.entity';

/**
 * Repository for {{pascalCase name}} data access.
 * Handles all database operations for the {{pascalCase name}} entity.
 *
 * @class {{pascalCase name}}Repository
 */
@Injectable()
export class {{pascalCase name}}Repository extends Repository<{{pascalCase name}}> {
  constructor(private readonly dataSource: DataSource) {
    super({{pascalCase name}}, dataSource.createEntityManager());
  }

  /**
   * Find {{camelCase name}} by a unique field.
